# =============================================
# Acasting Media Studio — Environment Variables
# =============================================
# Copia questo file come .env.local e compila i valori

# --- DATABASE (Neon o Supabase) ---
# Neon:     https://console.neon.tech
# Supabase: Settings → Database → Connection String → "URI"


# --- HUGGING FACE (opzionale, free tier) ---
# Crea account su https://huggingface.co
# Vai su https://huggingface.co/settings/tokens
# Genera un token con permesso "read"
# NOTA: crediti gratuiti limitati, si esauriscono
HUGGINGFACE_API_KEY=""

# --- MAGIC HOUR (opzionale, 100 crediti/giorno gratis) ---
# Crea account su https://magichour.ai
# Vai su https://dev.magichour.ai → crea API key
# 400 crediti signup + 100 crediti/giorno (riscattabili nella web app)


# --- POLLINATIONS ---
# Nessuna API key necessaria! Completamente gratuito e illimitato.
# Documentazione: https://image.pollinations.ai/

# =============================================
# SETUP RAPIDO
# =============================================
# 1. cp .env.example .env.local
# 2. Configura DATABASE_URL con Neon o Supabase
# 3. npm install
# 4. npm run db:push    (crea le tabelle)
# 5. npm run dev        (avvia su localhost:3000)
#
# Per Magic Hour: riscatta i 100 crediti/giorno
# andando su magichour.ai → "Daily Credits" ogni giorno
